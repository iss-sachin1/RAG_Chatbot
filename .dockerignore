# Keep the build context small and secrets out of the image.
node_modules
.next
out
build
.git
.gitignore

# Secrets — provide these at runtime (env_file / -e), never bake them in.
.env
.env.*
!.env.example

# Local tooling / artifacts
npm-debug.log*
yarn-error.log*
.vscode
.idea
.DS_Store
coverage
*.tsbuildinfo

# Docs and deploy files not needed inside the image
Dockerfile
.dockerignore
*.md

# Obsolete local vector-store artifacts
.chroma_venv
chroma_db
chroma_data
scratch_*
