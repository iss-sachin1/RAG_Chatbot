# Copy this file to `.env` (local) and set the same variables in your Vercel
# project settings (Settings -> Environment Variables). Do NOT commit real keys.

# ─── NVIDIA-hosted MiniMax-M3 (LLM) ──────────────────────────────────────────
# Get a key from https://build.nvidia.com/minimaxai/minimax-m3 (starts with "nvapi-").
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m3

# ─── Upstash Vector (vector store) ───────────────────────────────────────────
# Create an index at https://console.upstash.com/vector with a built-in
# embedding model (e.g. mixedbread-ai/mxbai-embed-large-v1), then copy its
# REST URL and REST token from the index's "Details" / "Connect" tab.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
